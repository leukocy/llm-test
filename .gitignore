# Runtime cache
cache/

# Dev debug scripts (not part of pytest suite)
api_tests/

# Temporary dev test files at project root
test_abort_feature.py
test_abort_real.py

# AIME probe scripts and raw sweep data (one-off research artifacts)
# aime_stable_pools.json is NOT ignored — it is runtime data read by benchmark_runner.
_probe_*.py
_export_*.py
_update_*.py
_aime_*.csv

# Generated test output
test_output_quality/

# Claude Code local settings (keep shared settings.json)
.github/.claude/settings.local.json

# Onboarding state (user preference)
.onboarding_state

# bench_workspace — 一次性测试脚本与产出归档（见 bench_workspace/README.md）
# scripts/ 可跟踪（含 git mv 迁入的历史脚本）；报告/归档/日志为生成物，忽略
bench_workspace/reports/
bench_workspace/archives/
bench_workspace/logs/
